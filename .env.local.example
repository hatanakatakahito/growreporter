# =====================================================================
# .env.local - ローカル開発時の環境変数テンプレート
# =====================================================================
# 使い方:
#   1. このファイルを `.env.local` にコピー
#   2. ローカルで Firebase Emulator Suite を使うときは VITE_USE_EMULATOR=true
#   3. 本番 Firebase に直接接続して動作確認したいときは VITE_USE_EMULATOR=false
# =====================================================================

# Firebase Emulator Suite を使うかどうか（true / false）
VITE_USE_EMULATOR=true

# Emulator のホスト名（通常は 127.0.0.1 のまま）
VITE_EMULATOR_HOST=127.0.0.1

# 注意:
# - .env (本番用 Firebase Web 設定) は別ファイルとして管理してください
# - .env.local は .gitignore に含まれており、コミットされません
