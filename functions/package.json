{
  "name": "growreporter-functions",
  "version": "1.1.0",
  "description": "Firebase Functions for GrowReporter - API on-demand strategy",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "migrate:taxonomy-v2": "node --loader ./loader.mjs src/scripts/migrateTaxonomyV2.js",
    "migrate:taxonomy-v2:dry": "node --loader ./loader.mjs src/scripts/migrateTaxonomyV2.js --dry-run",
    "batch:rescrape-all": "node --loader ./loader.mjs src/scripts/triggerAllSitesRescrape.js",
    "batch:rescrape-all:dry": "node --loader ./loader.mjs src/scripts/triggerAllSitesRescrape.js --dry-run"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "@sparticuz/chromium": "^123.0.1",
    "cheerio": "^1.0.0",
    "date-fns": "^4.1.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "googleapis": "^134.0.0",
    "nodemailer": "^8.0.1",
    "puppeteer-core": "^22.6.0",
    "uuid": "^11.0.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
