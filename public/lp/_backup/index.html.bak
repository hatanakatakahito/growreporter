<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>GROW REPORTER（グローレポーター）｜GA4 x AI アクセス解析ツール</title>
    <meta name="description" content="Google Analytics 4（GA4）とSearch ConsoleのデータをAIが自動で分析・考察し、サイト改善の提案からモックアップまで生成。分析・改善・評価のサイクルでサイトを成長させるアクセス解析ツール。" />
    <meta name="keywords" content="GA4,アクセス解析,AI分析,Google Analytics,Search Console,サイト改善,レポート自動生成,Web解析ツール" />
    <link rel="canonical" href="https://growreporter.web.app/lp/" />
    <meta property="og:title" content="GROW REPORTER｜GA4 x AI アクセス解析ツール" />
    <meta property="og:description" content="GA4とSearch ConsoleのデータをAIが自動分析。考察・改善提案・モックアップまで。サイトを成長させるアクセス解析ツール。" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://growreporter.web.app/lp/" />
    <meta property="og:image" content="https://growreporter.web.app/lp/assets/images/ogp.png" />
    <meta property="og:site_name" content="GROW REPORTER" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="GROW REPORTER｜GA4 x AI アクセス解析ツール" />
    <meta name="twitter:description" content="GA4とSearch ConsoleのデータをAIが自動分析。考察・改善提案・モックアップまで。" />
    <meta name="twitter:image" content="https://growreporter.web.app/lp/assets/images/ogp.png" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "GROW REPORTER",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "GA4とSearch ConsoleのデータをAIが自動で分析・考察し、サイト改善の提案からモックアップまで生成するアクセス解析ツール",
      "offers": [
        { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "name": "無料プラン" },
        { "@type": "Offer", "price": "9800", "priceCurrency": "JPY", "name": "スタンダードプラン" },
        { "@type": "Offer", "price": "29800", "priceCurrency": "JPY", "name": "プレミアムプラン" }
      ],
      "provider": { "@type": "Organization", "name": "GrowGroup株式会社", "address": { "@type": "PostalAddress", "addressLocality": "名古屋市", "addressRegion": "愛知県", "addressCountry": "JP" } }
    }
    </script>
    <link rel="icon" href="./favicon.ico" />
    <link rel="stylesheet" href="./assets/css/output.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      html { scroll-behavior: smooth; }
      body { font-family: 'Inter', 'Noto Sans JP', sans-serif; }
    </style>
  </head>

  <body
    x-data="{ scrolledFromTop: false }"
    x-init="window.pageYOffset >= 50 ? scrolledFromTop = true : scrolledFromTop = false"
    @scroll.window="window.pageYOffset >= 50 ? scrolledFromTop = true : scrolledFromTop = false"
  >

    <!-- ====== Navbar Section Start -->
    <header
      x-data="{ navbarOpen: false }"
      :class="scrolledFromTop ? 'fixed z-50 bg-white/80 shadow-sm backdrop-blur-sm' : 'absolute'"
      class="top-0 left-0 z-50 w-full"
    >
      <div class="container mx-auto">
        <div class="relative -mx-4 flex items-center justify-between">
          <div class="w-60 max-w-full px-4">
            <a href="/lp/" class="block w-full py-5">
              <img src="assets/images/logo.svg" alt="GROW REPORTER" class="w-full" />
            </a>
          </div>
          <div class="flex w-full items-center justify-between px-4">
            <div>
              <button
                @click="navbarOpen = !navbarOpen"
                :class="navbarOpen && 'navbarTogglerActive'"
                id="navbarToggler"
                class="ring-primary absolute top-1/2 right-4 block -translate-y-1/2 rounded-lg px-3 py-[6px] focus:ring-2 lg:hidden"
              >
                <span class="bg-body-color relative my-[6px] block h-[2px] w-[30px]"></span>
                <span class="bg-body-color relative my-[6px] block h-[2px] w-[30px]"></span>
                <span class="bg-body-color relative my-[6px] block h-[2px] w-[30px]"></span>
              </button>
              <nav
                x-transition
                :class="!navbarOpen && 'hidden'"
                id="navbarCollapse"
                class="absolute top-full right-4 w-full max-w-[250px] rounded-lg bg-white px-6 py-5 shadow transition-all lg:static lg:block lg:w-full lg:max-w-full lg:bg-transparent lg:shadow-none"
              >
                <ul class="block lg:flex">
                  <li>
                    <a href="#features" class="text-dark hover:text-primary flex py-2 text-base font-medium lg:ml-12 lg:inline-flex">
                      特長
                    </a>
                  </li>
                  <li>
                    <a href="#how-it-works" class="text-dark hover:text-primary flex py-2 text-base font-medium lg:ml-12 lg:inline-flex">
                      使い方
                    </a>
                  </li>
                  <li>
                    <a href="#pricing" class="text-dark hover:text-primary flex py-2 text-base font-medium lg:ml-12 lg:inline-flex">
                      料金
                    </a>
                  </li>
                  <li>
                    <a href="#faq" class="text-dark hover:text-primary flex py-2 text-base font-medium lg:ml-12 lg:inline-flex">
                      FAQ
                    </a>
                  </li>
                  <li>
                    <a href="#contact" class="text-dark hover:text-primary flex py-2 text-base font-medium lg:ml-12 lg:inline-flex">
                      お問い合わせ
                    </a>
                  </li>
                </ul>
              </nav>
            </div>
            <div class="hidden justify-end pr-16 sm:flex lg:pr-0">
              <a href="/login" class="text-dark hover:text-primary px-7 py-3 text-base font-medium">
                ログイン
              </a>
              <a href="/register" class="bg-primary hover:bg-primary/90 rounded-lg px-7 py-3 text-base font-medium text-white">
                無料で始める
              </a>
            </div>
          </div>
        </div>
      </div>
    </header>
    <!-- ====== Navbar Section End -->

    <!-- ====== Hero Section Start -->
    <div class="bg-primary relative pt-[120px] md:pt-[130px] lg:pt-[160px]">
      <div class="container mx-auto">
        <div class="-mx-4 flex flex-wrap items-center">
          <div class="w-full px-4">
            <div class="hero-content text-center">
              <h1 class="mx-auto mb-5 max-w-[600px] text-3xl leading-snug font-bold text-white sm:text-4xl md:text-[42px]">
                GA4 x AIで、<br>アクセス解析を<br class="sm:hidden">次のステージへ
              </h1>
              <p class="mx-auto mb-8 max-w-[520px] text-base leading-relaxed text-[#e4e4e4]">
                Google Analytics 4とSearch ConsoleのデータをAIが自動で分析・考察。<br class="hidden sm:inline">
                改善提案からモックアップ生成まで、サイト成長に必要なすべてを。
              </p>
              <ul class="flex flex-wrap items-center justify-center">
                <li class="mx-2 mb-3 sm:mx-4">
                  <a href="/register" class="text-dark inline-flex items-center justify-center rounded-lg bg-white px-5 py-4 text-center text-base font-medium hover:bg-white/90 sm:px-10">
                    無料で始める
                  </a>
                </li>
                <li class="mx-2 mb-3 sm:mx-4">
                  <a href="#features" class="flex items-center text-base font-medium text-white hover:opacity-80">
                    <span class="mr-3 flex h-12 w-12 items-center justify-center rounded-full border border-white/30">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7 0L7 14M7 14L13 8M7 14L1 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    詳しく見る
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <div class="w-full px-4">
            <div class="relative z-10 mx-auto max-w-[845px]">
              <div class="mt-16">
                <img
                  src="assets/images/screenshot-dashboard.png"
                  alt="GROW REPORTER ダッシュボード"
                  class="mx-auto max-w-full rounded-t-xl"
                />
              </div>
              <div class="absolute bottom-0 -left-9 z-[-1]">
                <svg width="134" height="106" viewBox="0 0 134 106" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="1.66667" cy="104" r="1.66667" transform="rotate(-90 1.66667 104)" fill="white"/>
                  <circle cx="16.3333" cy="104" r="1.66667" transform="rotate(-90 16.3333 104)" fill="white"/>
                  <circle cx="31" cy="104" r="1.66667" transform="rotate(-90 31 104)" fill="white"/>
                  <circle cx="45.6667" cy="104" r="1.66667" transform="rotate(-90 45.6667 104)" fill="white"/>
                  <circle cx="60.3333" cy="104" r="1.66667" transform="rotate(-90 60.3333 104)" fill="white"/>
                  <circle cx="88.6667" cy="104" r="1.66667" transform="rotate(-90 88.6667 104)" fill="white"/>
                  <circle cx="117.667" cy="104" r="1.66667" transform="rotate(-90 117.667 104)" fill="white"/>
                  <circle cx="74.6667" cy="104" r="1.66667" transform="rotate(-90 74.6667 104)" fill="white"/>
                  <circle cx="103" cy="104" r="1.66667" transform="rotate(-90 103 104)" fill="white"/>
                  <circle cx="132" cy="104" r="1.66667" transform="rotate(-90 132 104)" fill="white"/>
                  <circle cx="1.66667" cy="89.3333" r="1.66667" transform="rotate(-90 1.66667 89.3333)" fill="white"/>
                  <circle cx="16.3333" cy="89.3333" r="1.66667" transform="rotate(-90 16.3333 89.3333)" fill="white"/>
                  <circle cx="31" cy="89.3333" r="1.66667" transform="rotate(-90 31 89.3333)" fill="white"/>
                  <circle cx="45.6667" cy="89.3333" r="1.66667" transform="rotate(-90 45.6667 89.3333)" fill="white"/>
                  <circle cx="60.3333" cy="89.3338" r="1.66667" transform="rotate(-90 60.3333 89.3338)" fill="white"/>
                  <circle cx="88.6667" cy="89.3338" r="1.66667" transform="rotate(-90 88.6667 89.3338)" fill="white"/>
                  <circle cx="117.667" cy="89.3338" r="1.66667" transform="rotate(-90 117.667 89.3338)" fill="white"/>
                  <circle cx="74.6667" cy="89.3338" r="1.66667" transform="rotate(-90 74.6667 89.3338)" fill="white"/>
                  <circle cx="103" cy="89.3338" r="1.66667" transform="rotate(-90 103 89.3338)" fill="white"/>
                  <circle cx="132" cy="89.3338" r="1.66667" transform="rotate(-90 132 89.3338)" fill="white"/>
                  <circle cx="1.66667" cy="74.6673" r="1.66667" transform="rotate(-90 1.66667 74.6673)" fill="white"/>
                  <circle cx="16.3333" cy="74.6668" r="1.66667" transform="rotate(-90 16.3333 74.6668)" fill="white"/>
                  <circle cx="31" cy="74.6668" r="1.66667" transform="rotate(-90 31 74.6668)" fill="white"/>
                  <circle cx="45.6667" cy="74.6668" r="1.66667" transform="rotate(-90 45.6667 74.6668)" fill="white"/>
                </svg>
              </div>
              <div class="absolute -top-6 -right-6 z-[-1]">
                <svg width="134" height="106" viewBox="0 0 134 106" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="1.66667" cy="104" r="1.66667" transform="rotate(-90 1.66667 104)" fill="white"/>
                  <circle cx="16.3333" cy="104" r="1.66667" transform="rotate(-90 16.3333 104)" fill="white"/>
                  <circle cx="31" cy="104" r="1.66667" transform="rotate(-90 31 104)" fill="white"/>
                  <circle cx="45.6667" cy="104" r="1.66667" transform="rotate(-90 45.6667 104)" fill="white"/>
                  <circle cx="60.3333" cy="104" r="1.66667" transform="rotate(-90 60.3333 104)" fill="white"/>
                  <circle cx="88.6667" cy="104" r="1.66667" transform="rotate(-90 88.6667 104)" fill="white"/>
                  <circle cx="117.667" cy="104" r="1.66667" transform="rotate(-90 117.667 104)" fill="white"/>
                  <circle cx="74.6667" cy="104" r="1.66667" transform="rotate(-90 74.6667 104)" fill="white"/>
                  <circle cx="103" cy="104" r="1.66667" transform="rotate(-90 103 104)" fill="white"/>
                  <circle cx="132" cy="104" r="1.66667" transform="rotate(-90 132 104)" fill="white"/>
                  <circle cx="1.66667" cy="89.3333" r="1.66667" transform="rotate(-90 1.66667 89.3333)" fill="white"/>
                  <circle cx="16.3333" cy="89.3333" r="1.66667" transform="rotate(-90 16.3333 89.3333)" fill="white"/>
                  <circle cx="31" cy="89.3333" r="1.66667" transform="rotate(-90 31 89.3333)" fill="white"/>
                  <circle cx="45.6667" cy="89.3333" r="1.66667" transform="rotate(-90 45.6667 89.3333)" fill="white"/>
                  <circle cx="60.3333" cy="89.3338" r="1.66667" transform="rotate(-90 60.3333 89.3338)" fill="white"/>
                  <circle cx="88.6667" cy="89.3338" r="1.66667" transform="rotate(-90 88.6667 89.3338)" fill="white"/>
                  <circle cx="117.667" cy="89.3338" r="1.66667" transform="rotate(-90 117.667 89.3338)" fill="white"/>
                  <circle cx="74.6667" cy="89.3338" r="1.66667" transform="rotate(-90 74.6667 89.3338)" fill="white"/>
                  <circle cx="103" cy="89.3338" r="1.66667" transform="rotate(-90 103 89.3338)" fill="white"/>
                  <circle cx="132" cy="89.3338" r="1.66667" transform="rotate(-90 132 89.3338)" fill="white"/>
                  <circle cx="1.66667" cy="74.6673" r="1.66667" transform="rotate(-90 1.66667 74.6673)" fill="white"/>
                  <circle cx="16.3333" cy="74.6668" r="1.66667" transform="rotate(-90 16.3333 74.6668)" fill="white"/>
                  <circle cx="31" cy="74.6668" r="1.66667" transform="rotate(-90 31 74.6668)" fill="white"/>
                  <circle cx="45.6667" cy="74.6668" r="1.66667" transform="rotate(-90 45.6667 74.6668)" fill="white"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- ====== Hero Section End -->

    <!-- ====== Features Section Start -->
    <section id="features" class="bg-tg-bg relative pt-20 pb-12 lg:pt-[120px] lg:pb-[90px]">
      <div class="container mx-auto">
        <div class="-mx-4 mb-10 flex flex-wrap items-center lg:mb-[60px]">
          <div class="w-full px-4 lg:w-6/12">
            <div class="mb-[60px] max-w-[500px] xl:mb-[70px]">
              <span class="text-primary mb-2 block text-lg font-semibold">
                GROW REPORTERの特長
              </span>
              <h2 class="text-dark text-3xl font-bold sm:text-4xl md:text-[40px]">
                AIが自動で分析・考察し、<br>改善提案まで行います
              </h2>
            </div>
            <div class="-mx-4 flex flex-wrap">
              <div class="w-full max-w-[520px] px-4">
                <div class="group mb-12 flex">
                  <div class="border-primary bg-primary group-hover:text-primary mr-6 flex h-[60px] w-full max-w-[60px] items-center justify-center rounded-full border-2 text-xl font-semibold text-white group-hover:bg-transparent md:h-[80px] md:max-w-[80px] md:text-2xl">
                    01
                  </div>
                  <div class="w-full">
                    <h3 class="text-dark mb-4 text-xl font-semibold 2xl:text-[22px]">
                      GA4・Search Console<br>データの自動分析
                    </h3>
                    <p class="text-body-color text-base leading-relaxed">
                      複雑なGA4データを自動で取得し、AIが考察・要約を生成。専門知識がなくても、サイトの状況が一目でわかります。
                    </p>
                  </div>
                </div>
              </div>
              <div class="w-full max-w-[520px] px-4">
                <div class="group mb-12 flex">
                  <div class="border-primary bg-primary group-hover:text-primary mr-6 flex h-[60px] w-full max-w-[60px] items-center justify-center rounded-full border-2 text-xl font-semibold text-white group-hover:bg-transparent md:h-[80px] md:max-w-[80px] md:text-2xl">
                    02
                  </div>
                  <div class="w-full">
                    <h3 class="text-dark mb-4 text-xl font-semibold 2xl:text-[22px]">
                      AIによる改善提案と<br>モックアップ生成
                    </h3>
                    <p class="text-body-color text-base leading-relaxed">
                      分析結果に基づき、具体的な改善ポイントをAIが提案。さらに改善後のイメージをモックアップとして自動生成します。
                    </p>
                  </div>
                </div>
              </div>
              <div class="w-full max-w-[520px] px-4">
                <div class="group mb-12 flex">
                  <div class="border-primary bg-primary group-hover:text-primary mr-6 flex h-[60px] w-full max-w-[60px] items-center justify-center rounded-full border-2 text-xl font-semibold text-white group-hover:bg-transparent md:h-[80px] md:max-w-[80px] md:text-2xl">
                    03
                  </div>
                  <div class="w-full">
                    <h3 class="text-dark mb-4 text-xl font-semibold 2xl:text-[22px]">
                      改善効果の評価と<br>成長サイクルの確立
                    </h3>
                    <p class="text-body-color text-base leading-relaxed">
                      施策の効果をデータで評価し、次のアクションにつなげます。分析・改善・評価のサイクルでサイトを継続的に成長させます。
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="w-full px-4 lg:w-6/12">
            <div class="top-1/2 right-0 hidden w-1/2 lg:absolute lg:flex lg:-translate-y-1/2">
              <img
                src="assets/images/screenshot-analysis.png"
                alt="GROW REPORTER 分析画面"
                class="ml-auto max-w-full"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- ====== Features Section End -->

    <!-- ====== How It Works Section Start -->
    <section id="how-it-works" class="pt-20 pb-10 lg:pt-[120px] lg:pb-20">
      <div class="container mx-auto">
        <div class="-mx-4 flex flex-wrap">
          <div class="w-full px-4">
            <div class="mx-auto mb-[60px] max-w-[510px] text-center">
              <span class="text-primary mb-2 block text-lg font-semibold">
                HOW IT WORKS
              </span>
              <h2 class="text-dark mb-3 text-3xl leading-[1.2] font-bold sm:text-4xl md:text-[40px]">
                かんたん3ステップで開始
              </h2>
              <p class="text-body-color text-base">
                面倒な設定は不要。GA4アカウントを連携するだけで、すぐにAI分析を開始できます。
              </p>
            </div>
          </div>
        </div>

        <div class="-mx-4 flex flex-wrap justify-center">
          <div class="w-full px-4 md:w-1/2 lg:w-1/3">
            <div class="shadow-testimonial-6 mb-10 rounded-xl bg-white p-8 text-center sm:p-12 lg:px-6 lg:py-10 xl:p-10">
              <div class="bg-primary mx-auto mb-6 flex h-[70px] w-[70px] items-center justify-center rounded-full text-white">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
                </svg>
              </div>
              <span class="text-primary mb-2 block text-sm font-semibold">STEP 01</span>
              <h3 class="text-dark mb-4 text-xl font-semibold">
                無料アカウント登録
              </h3>
              <p class="text-body-color text-base leading-relaxed">
                メールアドレスまたはGoogleアカウントで簡単に登録。クレジットカード不要で今すぐ始められます。
              </p>
            </div>
          </div>
          <div class="w-full px-4 md:w-1/2 lg:w-1/3">
            <div class="shadow-testimonial-6 mb-10 rounded-xl bg-white p-8 text-center sm:p-12 lg:px-6 lg:py-10 xl:p-10">
              <div class="bg-primary mx-auto mb-6 flex h-[70px] w-[70px] items-center justify-center rounded-full text-white">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
              </div>
              <span class="text-primary mb-2 block text-sm font-semibold">STEP 02</span>
              <h3 class="text-dark mb-4 text-xl font-semibold">
                GA4アカウントを連携
              </h3>
              <p class="text-body-color text-base leading-relaxed">
                Googleアカウントで認証するだけでGA4とSearch Consoleのデータが自動で連携されます。
              </p>
            </div>
          </div>
          <div class="w-full px-4 md:w-1/2 lg:w-1/3">
            <div class="shadow-testimonial-6 mb-10 rounded-xl bg-white p-8 text-center sm:p-12 lg:px-6 lg:py-10 xl:p-10">
              <div class="bg-primary mx-auto mb-6 flex h-[70px] w-[70px] items-center justify-center rounded-full text-white">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
              </div>
              <span class="text-primary mb-2 block text-sm font-semibold">STEP 03</span>
              <h3 class="text-dark mb-4 text-xl font-semibold">
                AI分析レポートを確認
              </h3>
              <p class="text-body-color text-base leading-relaxed">
                AIがデータを自動で分析。考察・改善提案・モックアップ生成まで、すべてお任せください。
