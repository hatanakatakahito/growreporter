# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google OAuth 2.0
# 注意: VITE_ プレフィックスはクライアント JS バンドルに含まれます。
# Client ID は公開前提なので OK ですが、Client Secret は絶対にここに置かないでください。
# Client Secret は functions/.env または Firebase Secret Manager 経由で backend のみで管理します。
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Google Cloud Project
VITE_GCP_PROJECT_ID=your_gcp_project_id
